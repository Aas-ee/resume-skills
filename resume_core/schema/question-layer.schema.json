{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resume-core.local/schema/question-layer.schema.json",
  "title": "Resume Core Guided Intake Question Layer",
  "type": "object",
  "$defs": {
    "Version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "FieldId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\[\\])?(\\.[a-zA-Z0-9]+(\\[\\])?)*$"
    },
    "GuidedIntakeQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fieldId", "question"],
      "properties": {
        "fieldId": {
          "$ref": "#/$defs/FieldId"
        },
        "question": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "GuidedIntakeQuestionSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questionSetId",
        "templateId",
        "templateVersion",
        "questions",
        "generatedAt"
      ],
      "properties": {
        "questionSetId": {
          "type": "string",
          "minLength": 1
        },
        "templateId": {
          "type": "string",
          "minLength": 1
        },
        "templateVersion": {
          "$ref": "#/$defs/Version"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GuidedIntakeQuestion"
          }
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
