{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resume-core.local/schema/response-layer.schema.json",
  "title": "Resume Core Guided Intake Response Layer",
  "type": "object",
  "$defs": {
    "Version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "FieldId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\[\\])?(\\.[a-zA-Z0-9]+(\\[\\])?)*$"
    },
    "GuidedIntakeResponseSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "responseSetId",
        "templateId",
        "templateVersion",
        "questionSetId",
        "responses",
        "updatedAt"
      ],
      "properties": {
        "responseSetId": {
          "type": "string",
          "minLength": 1
        },
        "templateId": {
          "type": "string",
          "minLength": 1
        },
        "templateVersion": {
          "$ref": "#/$defs/Version"
        },
        "questionSetId": {
          "type": "string",
          "minLength": 1
        },
        "responses": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/FieldId"
          },
          "additionalProperties": true
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
